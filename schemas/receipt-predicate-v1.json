{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.dev/schemas/receipt-predicate-v1.json",
  "title": "Aegis ExecutionReceipt predicate v1",
  "description": "Current Aegis predicate payload embedded inside an in-toto Statement v1 and wrapped in DSSE.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "execution_id",
    "backend",
    "result_class",
    "policy_digest",
    "policy",
    "evidence_digest",
    "evidence_digest_algo",
    "runtime_event_count",
    "point_decisions",
    "divergence",
    "outcome",
    "trust",
    "started_at",
    "finished_at",
    "signer_key_id"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "execution_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workflow_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "backend": {
      "type": "string",
      "enum": [
        "firecracker",
        "gvisor"
      ]
    },
    "task_class": {
      "$ref": "#/$defs/non_empty_string"
    },
    "declared_purpose": {
      "$ref": "#/$defs/non_empty_string"
    },
    "workspace_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "execution_status": {
      "$ref": "#/$defs/non_empty_string"
    },
    "semantics_mode": {
      "type": "string",
      "enum": [
        "explicit_v1",
        "legacy_derived"
      ]
    },
    "result_class": {
      "type": "string",
      "enum": [
        "completed",
        "denied",
        "abnormal",
        "reconciled"
      ]
    },
    "denial": {
      "$ref": "#/$defs/denial_summary"
    },
    "policy_digest": {
      "$ref": "#/$defs/non_empty_string"
    },
    "intent_digest": {
      "$ref": "#/$defs/digest_hex"
    },
    "intent_digest_algo": {
      "$ref": "#/$defs/non_empty_string"
    },
    "policy": {
      "$ref": "#/$defs/policy_envelope"
    },
    "evidence_digest": {
      "$ref": "#/$defs/digest_hex"
    },
    "evidence_digest_algo": {
      "$ref": "#/$defs/non_empty_string"
    },
    "runtime_event_count": {
      "type": "integer",
      "minimum": 0
    },
    "point_decisions": {
      "$ref": "#/$defs/point_decision_summary"
    },
    "divergence": {
      "$ref": "#/$defs/divergence_summary"
    },
    "outcome": {
      "$ref": "#/$defs/outcome"
    },
    "runtime": {
      "$ref": "#/$defs/runtime_envelope"
    },
    "trust": {
      "$ref": "#/$defs/trust_posture"
    },
    "limitations": {
      "$ref": "#/$defs/string_list"
    },
    "started_at": {
      "$ref": "#/$defs/date_time"
    },
    "finished_at": {
      "$ref": "#/$defs/date_time"
    },
    "signer_key_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "broker_summary": {
      "$ref": "#/$defs/broker_summary"
    },
    "governed_actions": {
      "$ref": "#/$defs/governed_action_summary"
    },
    "metadata": {
      "$ref": "#/$defs/string_map"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "digest_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{32,}$"
    },
    "string_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "string_list_or_null": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "string_map": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "denial_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class"
      ],
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "governed_action",
            "policy"
          ]
        },
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "marker": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "point_decision_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_count",
        "deny_count",
        "not_applicable_count"
      ],
      "properties": {
        "allow_count": {
          "type": "integer",
          "minimum": 0
        },
        "deny_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_applicable_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "divergence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "rule_hit_count"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "allow",
            "warn",
            "kill_candidate"
          ]
        },
        "triggered_rule_ids": {
          "$ref": "#/$defs/string_list"
        },
        "rule_hit_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ExitCode",
        "Reason",
        "ContainmentVerdict",
        "OutputTruncated"
      ],
      "properties": {
        "ExitCode": {
          "type": "integer"
        },
        "Reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ContainmentVerdict": {
          "$ref": "#/$defs/non_empty_string"
        },
        "OutputTruncated": {
          "type": "boolean"
        }
      }
    },
    "policy_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline"
      ],
      "properties": {
        "baseline": {
          "$ref": "#/$defs/baseline_policy"
        },
        "intent": {
          "$ref": "#/$defs/intent_policy_digest"
        }
      }
    },
    "baseline_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "code_size_bytes",
        "max_code_bytes",
        "timeout_ms",
        "max_timeout_ms"
      ],
      "properties": {
        "language": {
          "$ref": "#/$defs/non_empty_string"
        },
        "code_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "max_code_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "profile": {
          "$ref": "#/$defs/non_empty_string"
        },
        "network": {
          "$ref": "#/$defs/baseline_network_policy"
        }
      }
    },
    "baseline_network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "description": "The `direct_web_egress`, `isolated`, and `allowlist` values are deprecated and accepted only for verification of pre-Pass-A receipts. Receipts produced after Pass A MUST use `egress_allowlist`.",
          "enum": [
            "none",
            "direct_web_egress",
            "isolated",
            "allowlist",
            "egress_allowlist"
          ]
        },
        "presets": {
          "$ref": "#/$defs/string_list_or_null"
        },
        "allowlist": {
          "$ref": "#/$defs/network_allowlist"
        }
      }
    },
    "network_allowlist": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fqdns": {
          "$ref": "#/$defs/string_list"
        },
        "cidrs": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "intent_policy_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest"
      ],
      "properties": {
        "digest": {
          "$ref": "#/$defs/digest_hex"
        },
        "source": {
          "type": "string",
          "enum": [
            "intent_contract",
            "compiled_capabilities"
          ]
        }
      }
    },
    "runtime_envelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "$ref": "#/$defs/non_empty_string"
        },
        "vcpu_count": {
          "type": "integer",
          "minimum": 0
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 0
        },
        "cgroup": {
          "$ref": "#/$defs/runtime_cgroup"
        },
        "network": {
          "$ref": "#/$defs/runtime_network"
        },
        "broker": {
          "$ref": "#/$defs/runtime_broker"
        },
        "applied_overrides": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "runtime_cgroup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "memory_max_mb": {
          "type": "integer",
          "minimum": 0
        },
        "memory_high_mb": {
          "type": "integer",
          "minimum": 0
        },
        "pids_max": {
          "type": "integer",
          "minimum": 0
        },
        "cpu_max": {
          "$ref": "#/$defs/non_empty_string"
        },
        "swap_max": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "runtime_network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "mode"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "description": "The `direct_web_egress`, `isolated`, and `allowlist` values are deprecated and accepted only for verification of pre-Pass-A receipts. Receipts produced after Pass A MUST use `egress_allowlist`.",
          "enum": [
            "none",
            "direct_web_egress",
            "isolated",
            "allowlist",
            "egress_allowlist"
          ]
        },
        "presets": {
          "$ref": "#/$defs/string_list_or_null"
        },
        "allowlist": {
          "$ref": "#/$defs/network_allowlist"
        }
      }
    },
    "runtime_broker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "trust_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signing_mode",
        "key_source",
        "attestation",
        "verification_material"
      ],
      "properties": {
        "signing_mode": {
          "type": "string",
          "enum": [
            "dev",
            "strict"
          ]
        },
        "key_source": {
          "type": "string",
          "enum": [
            "configured_seed",
            "dev_fallback"
          ]
        },
        "attestation": {
          "$ref": "#/$defs/non_empty_string"
        },
        "verification_material": {
          "$ref": "#/$defs/non_empty_string"
        },
        "limitations": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "broker_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_count",
        "allowed_count",
        "denied_count"
      ],
      "properties": {
        "request_count": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_count": {
          "type": "integer",
          "minimum": 0
        },
        "denied_count": {
          "type": "integer",
          "minimum": 0
        },
        "domains_allowed": {
          "$ref": "#/$defs/string_list"
        },
        "domains_denied": {
          "$ref": "#/$defs/string_list"
        },
        "bindings_used": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "governed_action_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/governed_action_record"
          }
        },
        "normalized": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/normalized_governed_action"
          }
        }
      }
    },
    "governed_action_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_type",
        "target",
        "decision",
        "used",
        "brokered",
        "brokered_credentials"
      ],
      "properties": {
        "action_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target": {
          "$ref": "#/$defs/non_empty_string"
        },
        "resource": {
          "$ref": "#/$defs/non_empty_string"
        },
        "method": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capability_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "$ref": "#/$defs/non_empty_string"
        },
        "outcome": {
          "$ref": "#/$defs/non_empty_string"
        },
        "used": {
          "type": "boolean"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy_digest": {
          "$ref": "#/$defs/non_empty_string"
        },
        "brokered": {
          "type": "boolean"
        },
        "brokered_credentials": {
          "type": "boolean"
        },
        "binding_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "response_digest": {
          "$ref": "#/$defs/digest_hex"
        },
        "response_digest_algo": {
          "$ref": "#/$defs/non_empty_string"
        },
        "denial_marker": {
          "$ref": "#/$defs/non_empty_string"
        },
        "audit_payload": {
          "$ref": "#/$defs/string_map"
        },
        "error": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "normalized_governed_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "action_type",
        "target",
        "decision",
        "used",
        "brokered",
        "brokered_credentials"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "action_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target": {
          "$ref": "#/$defs/non_empty_string"
        },
        "resource": {
          "$ref": "#/$defs/non_empty_string"
        },
        "method": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capability_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "$ref": "#/$defs/non_empty_string"
        },
        "outcome": {
          "$ref": "#/$defs/non_empty_string"
        },
        "used": {
          "type": "boolean"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy_digest": {
          "$ref": "#/$defs/non_empty_string"
        },
        "brokered": {
          "type": "boolean"
        },
        "brokered_credentials": {
          "type": "boolean"
        },
        "binding_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "response_digest": {
          "$ref": "#/$defs/digest_hex"
        },
        "response_digest_algo": {
          "$ref": "#/$defs/non_empty_string"
        },
        "denial_marker": {
          "$ref": "#/$defs/non_empty_string"
        },
        "audit_payload": {
          "$ref": "#/$defs/string_map"
        },
        "error": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
