{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.dev/schemas/intent-v1.json",
  "title": "Aegis IntentContract v1",
  "description": "Product-facing execution intent contract for Aegis v2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "execution_id",
    "workflow_id",
    "task_class",
    "declared_purpose",
    "language",
    "resource_scope",
    "network_scope",
    "process_scope",
    "broker_scope",
    "budgets"
  ],
  "properties": {
    "version": {
      "const": "v1",
      "description": "Schema version for this intent contract."
    },
    "execution_id": {
      "$ref": "#/$defs/id"
    },
    "workflow_id": {
      "$ref": "#/$defs/id"
    },
    "task_class": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "description": "Stable task classification used for policy and divergence evaluation."
    },
    "declared_purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Human-readable statement of intended work."
    },
    "language": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9.+_-]+$",
      "description": "Primary execution language or toolchain label."
    },
    "backend_hint": {
      "type": "string",
      "enum": [
        "firecracker",
        "gvisor"
      ],
      "description": "Optional backend preference. The orchestrator may ignore this hint."
    },
    "resource_scope": {
      "$ref": "#/$defs/resource_scope"
    },
    "network_scope": {
      "$ref": "#/$defs/network_scope"
    },
    "process_scope": {
      "$ref": "#/$defs/process_scope"
    },
    "broker_scope": {
      "$ref": "#/$defs/broker_scope"
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "attributes": {
      "type": "object",
      "description": "Optional string attributes carried into orchestrator context and Cedar compilation.",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-zA-Z0-9_.-]+$"
      },
      "additionalProperties": {
        "type": "string",
        "maxLength": 512
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
      "description": "Stable identifier generated by the orchestrator."
    },
    "abs_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^/.*",
      "description": "Absolute path inside the isolated execution environment."
    },
    "path_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/abs_path"
      },
      "maxItems": 256,
      "uniqueItems": true
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^(?=.{1,253}$)(?!-)(?:[A-Za-z0-9-]{1,63}\\.)+[A-Za-z]{2,63}$",
      "description": "Fully qualified domain name without scheme or path."
    },
    "domain_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain"
      },
      "maxItems": 256,
      "uniqueItems": true
    },
    "ip_address": {
      "type": "string",
      "format": "ipv4",
      "description": "Literal IPv4 address. CIDR ranges are out of scope for v1."
    },
    "ip_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ip_address"
      },
      "maxItems": 256,
      "uniqueItems": true
    },
    "binary_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._+-]+$",
      "description": "Binary name or basename allowed for execution."
    },
    "delegation_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "description": "Named brokered capability delegated to the host."
    },
    "non_negative_int": {
      "type": "integer",
      "minimum": 0
    },
    "positive_int": {
      "type": "integer",
      "minimum": 1
    },
    "resource_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_root",
        "read_paths",
        "write_paths",
        "deny_paths",
        "max_distinct_files"
      ],
      "properties": {
        "workspace_root": {
          "$ref": "#/$defs/abs_path"
        },
        "read_paths": {
          "allOf": [
            {
              "$ref": "#/$defs/path_list"
            }
          ],
          "description": "Absolute paths the workload may read. Enforcement still depends on sandbox isolation and resolved-object checks."
        },
        "write_paths": {
          "allOf": [
            {
              "$ref": "#/$defs/path_list"
            }
          ],
          "description": "Absolute paths the workload may create or modify."
        },
        "deny_paths": {
          "allOf": [
            {
              "$ref": "#/$defs/path_list"
            }
          ],
          "description": "Absolute paths treated as explicit deny targets even if broader scopes would otherwise match."
        },
        "max_distinct_files": {
          "$ref": "#/$defs/positive_int",
          "description": "Upper bound on distinct file paths touched during execution."
        }
      }
    },
    "network_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_network",
        "allowed_domains",
        "allowed_ips",
        "max_dns_queries",
        "max_outbound_conns"
      ],
      "properties": {
        "allow_network": {
          "type": "boolean",
          "description": "Whether any outbound network activity is permitted."
        },
        "allowed_domains": {
          "allOf": [
            {
              "$ref": "#/$defs/domain_list"
            }
          ],
          "description": "Domain allowlist for broker-free outbound access."
        },
        "allowed_ips": {
          "allOf": [
            {
              "$ref": "#/$defs/ip_list"
            }
          ],
          "description": "Literal IPv4 allowlist for outbound connections."
        },
        "max_dns_queries": {
          "$ref": "#/$defs/non_negative_int",
          "description": "Upper bound on DNS lookup attempts observed for this execution."
        },
        "max_outbound_conns": {
          "$ref": "#/$defs/non_negative_int",
          "description": "Upper bound on outbound connection attempts."
        }
      }
    },
    "process_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_binaries",
        "allow_shell",
        "allow_package_install",
        "max_child_processes"
      ],
      "properties": {
        "allowed_binaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/binary_name"
          },
          "maxItems": 256,
          "uniqueItems": true,
          "description": "Binary names explicitly permitted for execution."
        },
        "allow_shell": {
          "type": "boolean",
          "description": "Whether shell interpreters or shell-style command execution are allowed."
        },
        "allow_package_install": {
          "type": "boolean",
          "description": "Whether package manager installation actions are allowed."
        },
        "max_child_processes": {
          "$ref": "#/$defs/non_negative_int",
          "description": "Upper bound on child processes created during the execution."
        }
      }
    },
    "broker_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_delegations",
        "require_host_consent"
      ],
      "properties": {
        "allowed_delegations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/delegation_name"
          },
          "maxItems": 128,
          "uniqueItems": true,
          "description": "Named operations the guest may request from the host broker over a controlled channel."
        },
        "require_host_consent": {
          "type": "boolean",
          "description": "Whether each brokered action requires an explicit host-side approval decision."
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeout_sec",
        "memory_mb",
        "cpu_quota",
        "stdout_bytes"
      ],
      "properties": {
        "timeout_sec": {
          "$ref": "#/$defs/positive_int",
          "description": "Wall-clock timeout budget in seconds."
        },
        "memory_mb": {
          "$ref": "#/$defs/positive_int",
          "description": "Memory limit in mebibytes."
        },
        "cpu_quota": {
          "$ref": "#/$defs/positive_int",
          "description": "CPU quota value interpreted by the orchestrator backend."
        },
        "stdout_bytes": {
          "$ref": "#/$defs/positive_int",
          "description": "Maximum captured stdout and stderr payload size in bytes."
        }
      }
    }
  }
}
